{
  "name": "sortingtest",
  "version": "1.0.0",
  "description": "Простой Express сервер на TypeScript",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:nodemon": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:bcrypt --external:mongodb",
    "build:clean": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:bcrypt --external:mongodb",
    "watch": "tsc -w",
    "devs": "nodemon --exec ts-node src/index.ts",
    "heroku-postbuild": "yarn build",
    "test": "jest --detectOpenHandles --no-cache --runInBand",
    "sorting": "ts-node src/models/sorting.ts",
    "test:mongo": "ts-node src/testMongo.ts"
  },
  "dependencies": {
    "@types/jest": "29",
    "@types/nodemailer": "^7.0.9",
    "@types/supertest": "^6.0.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jest": "29",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.3",
    "mailtrap": "^4.4.0",
    "mongodb": "^7.0.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.12.1",
    "ngrok": "5.0.0-beta.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "socket.io": "^4.8.3",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.6",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongodb": "^4.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.27.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
